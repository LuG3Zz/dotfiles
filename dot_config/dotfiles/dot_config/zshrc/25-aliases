# -----------------------------------------------------
# ALIASES
# -----------------------------------------------------

# -----------------------------------------------------
# General
# -----------------------------------------------------
alias c='clear'
alias nf='fastfetch'
alias pf='fastfetch'
alias ff='fastfetch'
alias v='$EDITOR'
alias vim='$EDITOR'
alias so='source'
alias shutdown='systemctl poweroff'
alias reboot='systemctl reboot'
alias lzg='lazygit'
alias lzd='sudo lazydocker'
alias oc='opencode'

# -----------------------------------------------------
# ls (eza) — with --group-directories-first for cleaner output
# -----------------------------------------------------
alias ls='eza --icons --group-directories-first'
alias ll='eza -l --icons --git --group-directories-first'
alias la='eza -la --icons --git --group-directories-first'
alias lt='eza --tree --icons --group-directories-first'
alias tree='eza --tree --icons --group-directories-first'
alias llt='eza -l --icons --git --tree --level=2 --group-directories-first'

# -----------------------------------------------------
# cat (bat)
# -----------------------------------------------------
if command -v batcat &> /dev/null; then
  alias cat='batcat'
  alias catp='batcat --paging=never'
else
  alias cat='bat'
  alias catp='bat --paging=never'
fi

# -----------------------------------------------------
# fd
# -----------------------------------------------------
if command -v fdfind &> /dev/null; then
  alias fd='fdfind'
fi

# -----------------------------------------------------
# grep (ripgrep)
# -----------------------------------------------------
alias grep='rg'

# -----------------------------------------------------
# Safe defaults
# -----------------------------------------------------
alias cp='cp -iv'
alias mv='mv -iv'
alias rm='rm -i'
alias mkdir='mkdir -p'
alias df='df -h'
alias du='du -h'
alias free='free -h'

# -----------------------------------------------------
# Navigation
# -----------------------------------------------------
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias d='dirs -v'
alias 1='cd -'
alias 2='cd -2'
alias 3='cd -3'

# -----------------------------------------------------
# System
# -----------------------------------------------------
alias update-grub='sudo grub-mkconfig -o /boot/grub/grub.cfg'
alias pac='sudo pacman'
alias pacs='pacman -Ss'
alias pacu='sudo pacman -Syu'
alias pacr='sudo pacman -Rns'
alias pacq='pacman -Q'
alias yays='yay -Ss'
alias yayu='yay -Syu'

# -----------------------------------------------------
# Git
# -----------------------------------------------------
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git log --oneline --graph'
alias gd='git diff'
